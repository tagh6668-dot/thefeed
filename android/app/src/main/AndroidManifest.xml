<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Saving downloads on Android 9 and below uses
         Environment.getExternalStoragePublicDirectory which requires
         WRITE_EXTERNAL_STORAGE. Android 10+ uses MediaStore (scoped
         storage) and needs no permission, so cap maxSdkVersion at 28
         to avoid asking for a no-op permission on modern devices. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Auto Backup OFF: the Saved store is sealed with a random per-device key
         kept in filesDir. Google's cloud backup/restore can bring that key and
         the sealed store back in a mismatched state on a reinstall / new device,
         surfacing as "device encryption key lost" or empty Saved Messages.
         Device migration is handled by the app's own encrypted Backup/Restore. -->
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:extractNativeLibs="true"
        android:theme="@style/Theme.Thefeed">

        <service
            android:name=".ThefeedService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|keyboard|uiMode|density|locale|layoutDirection|fontScale">
            <!-- configChanges keeps the activity (and its WebView) alive
                 across rotation, keyboard show/hide, dark-mode toggles,
                 display-zoom changes, and runtime locale switches.
                 Without this, every rotation tore down MainActivity and
                 the WebView came back blank — onCreate would reload
                 http://127.0.0.1:<port>/, losing scroll position and any
                 client-side state (open lightboxes, chat draft, scanner
                 progress). Process death is still possible (low memory,
                 force-stop); on the next launch the activity restarts
                 fresh via waitForServerThenLoad — acceptable because the
                 service pins its port to a stable range so localStorage
                 persists. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>
    </application>

</manifest>
